<Window x:Class="WpfApp1.Window_Transacoes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="390" Width="646">
    <Grid Margin="0,0,0,4">
        <Rectangle HorizontalAlignment="Center" Height="2" Margin="0,65,0,0" Stroke="Black" VerticalAlignment="Top" Width="646" RenderTransformOrigin="0.5,0.5">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleY="-1"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <Button x:Name="botaoDepositar" Content="Depositar" HorizontalAlignment="Left" Margin="63,258,0,0" VerticalAlignment="Top" Height="38" Width="99" Background="AliceBlue" Click="botaoDepositar_Click"/>
        <Button x:Name="botaoSacar" Content="Sacar" HorizontalAlignment="Left" Margin="180,259,0,0" VerticalAlignment="Top" Height="36" Width="98" Background="AliceBlue" Click="botaoSacar_Click"/>
        <Button x:Name="botaoTransferir" Content="Transferir" HorizontalAlignment="Left" Margin="298,259,0,0" VerticalAlignment="Top" Height="37" Width="99" Background="AliceBlue" Click="botaoTransferir_Click"/>
        <Label Content="Número da Conta A:" HorizontalAlignment="Left" Margin="93,124,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="textBoxNumeroContaA"  Grid.Row="0" Margin="221,124,310,207" />
        <Label Content="Número da Conta B:" HorizontalAlignment="Left" Margin="93,168,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="textBoxNumeroContaB"  Grid.Row="0" Margin="221,168,310,162" />
        <Label Content="Valor:" HorizontalAlignment="Left" Margin="93,213,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="textBoxValor"  Grid.Row="0" Margin="161,213,310,117" />
        <Button Content="Voltar" HorizontalAlignment="Left" Margin="18,10,0,0" VerticalAlignment="Top" Height="35" Width="94" Click="Button_Click"/>
        <Image HorizontalAlignment="Left" Height="233" Margin="420,80,0,0" VerticalAlignment="Top" Width="216" Source="/View/logoFinancia.png"/>

    </Grid>
</Window>
