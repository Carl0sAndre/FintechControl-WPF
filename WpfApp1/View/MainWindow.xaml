<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="390" Width="646">
    <Grid Margin="0,0,0,4">
        <Rectangle HorizontalAlignment="Left" Height="1" Margin="0,42,0,0" Stroke="Black" VerticalAlignment="Top" Width="643" RenderTransformOrigin="0.5,0.5">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleY="-1"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <DataGrid x:Name="dataGridClientes" 
          Margin="0,231,0,0" AutoGenerateColumns="True"/>
        <Button x:Name="botaoCadastro" Content="Cadastrar Cliente" HorizontalAlignment="Left" Margin="42,83,0,0" VerticalAlignment="Top" Height="37" Width="99" Background="AliceBlue" Click="botaoCadastro_Click"/>
        <Button x:Name="botaoTransacao" Content="Transações" HorizontalAlignment="Left" Margin="42,159,0,0" VerticalAlignment="Top" Height="37" Width="99" Background="AliceBlue" Click="botaoTransacao_Click"/>
        <Button x:Name="botaoExcluir" Content="Excluir Clientes" HorizontalAlignment="Left" Margin="207,83,0,0" VerticalAlignment="Top" Height="37" Width="99" Background="AliceBlue" Click="botaoExcluir_Click"/>
        <Button x:Name="botaoListar" Content="Listar Clientes" HorizontalAlignment="Left" Margin="207,159,0,0" VerticalAlignment="Top" Height="37" Width="99" Background="AliceBlue" Click="botaoListar_Click"/>
        <Image HorizontalAlignment="Left" Height="178" Margin="393,48,0,0" VerticalAlignment="Top" Width="309" Source="/View/logoFinancia.png"/>
        <Button Content="Aplicar rendimentos" HorizontalAlignment="Left" Height="27" Margin="28,10,0,0" Background="AliceBlue" VerticalAlignment="Top" Width="113" Click="Button_Click"/>

    </Grid>
</Window>
