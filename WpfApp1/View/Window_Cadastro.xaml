<Window x:Class="WpfApp1.Window_Cadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Criar Conta Bancária" Height="375" Width="676"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0,0,0,-16">

        <Label Content="Nome:" Grid.Column="0" VerticalAlignment="Top" Margin="2,21,485,0" />
        <TextBox x:Name="textBoxNome" Grid.Row="0" Margin="67,10,236,313" />

        <Label Content="Banco:" Grid.Column="0" VerticalAlignment="Top" Margin="0,71,378,0" />
        <TextBox x:Name="textBoxBanco" Margin="67,67,236,259" />

        <Label Content="CPF:" Grid.Column="0" VerticalAlignment="Top" Margin="4,132,486,0" />
        <TextBox x:Name="textBoxCPF" Margin="68,121,235,201" />

        <Label Content="Endereço:" Grid.Column="0" VerticalAlignment="Top" Margin="0,198,482,0" />
        <TextBox x:Name="textBoxEndereco" Margin="67,188,235,131" />



        <Button x:Name="botaoContaCorrente" Content="Criar Conta Corrente" Margin="149,280,356,45" Padding="10,5" Click="botaoContaCorrente_Click" />
        <Button x:Name="botaoPoupanca" Content="Criar Poupança" Margin="338,280,167,45" Padding="10,5" Click="botaoPoupanca_Click" />


        <Image HorizontalAlignment="Left" Height="231" Margin="446,34,0,0" VerticalAlignment="Top" Width="222" Source="/View/logoFinancia.png"/>
        <Button x:Name="botaoVoltar" Content="Voltar" HorizontalAlignment="Left" Height="22" Margin="35,283,0,0" VerticalAlignment="Top" Width="46" Click="botaoVoltar_Click"/>

    </Grid>
</Window>